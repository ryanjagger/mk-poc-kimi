            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Users/ryan/gauntlet/mk-poc-kimi/node_modules/.pnpm/esbuild@0.21.5/node_modules/esbuild/node_modules:/Users/ryan/gauntlet/mk-poc-kimi/node_modules/.pnpm/esbuild@0.21.5/node_modules:/Users/ryan/gauntlet/mk-poc-kimi/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/Users/ryan/gauntlet/mk-poc-kimi/node_modules/.pnpm/esbuild@0.21.5/node_modules/esbuild/node_modules:/Users/ryan/gauntlet/mk-poc-kimi/node_modules/.pnpm/esbuild@0.21.5/node_modules:/Users/ryan/gauntlet/mk-poc-kimi/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../esbuild/bin/esbuild" "$@"
else
  exec node  "$basedir/../../../esbuild/bin/esbuild" "$@"
fi
